# Slack (Socket Mode) — create the app at https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...     # Bot User OAuth Token — scopes: app_mentions:read, chat:write, groups:history
SLACK_APP_TOKEN=xapp-...     # App-Level Token — scope: connections:write (enables Socket Mode, no public URL)

# CMA / Anthropic — for the real conversational agent (replaces the interpret() seam)
ANTHROPIC_API_KEY=sk-ant-...
